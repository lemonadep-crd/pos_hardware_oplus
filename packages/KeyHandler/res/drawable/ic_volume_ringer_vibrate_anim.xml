<?xml version="1.0" encoding="utf-8"?>
<!--
    SPDX-FileCopyrightText: 2026 The LineageOS Project
    SPDX-License-Identifier: Apache-2.0

    Vibrate micro-interaction:
    - Outer bars (left_outer, right_outer) pulse in/out fast with 0ms start
    - Inner bars (left_inner, right_inner) pulse in/out fast with 140ms offset
    - Creates a ripple/haptic wave effect emanating from the phone body outward
    - Seamless infinite loop, sine-wave easing via fast_out_slow_in
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_volume_ringer_vibrate">

    <target android:name="left_outer">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1.0"
                    android:valueTo="0.25"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.3"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="right_outer">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1.0"
                    android:valueTo="0.25"
                    android:startOffset="160"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.3"
                    android:startOffset="160"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="left_inner">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1.0"
                    android:valueTo="0.4"
                    android:startOffset="80"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.5"
                    android:startOffset="80"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="right_inner">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="1.0"
                    android:valueTo="0.4"
                    android:startOffset="240"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:valueFrom="1.0"
                    android:valueTo="0.5"
                    android:startOffset="240"
                    android:duration="320"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>