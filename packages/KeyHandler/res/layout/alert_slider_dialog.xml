<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alert_slider_dialog"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true"
    android:clipToPadding="false"
    android:layout_margin="@dimen/alert_slider_container_padding"
    android:background="@drawable/alert_slider_bg"
    android:theme="@style/alert_slider_theme">

    <LinearLayout
        android:id="@+id/alert_slider_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|right"
        android:orientation="horizontal"
        android:paddingStart="@dimen/alert_slider_padding"
        android:paddingEnd="@dimen/alert_slider_padding"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:translationZ="@dimen/alert_slider_elevation">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <ImageView
                android:id="@+id/alert_slider_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/alert_slider_emoji_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="22sp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/alert_slider_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:fontFamily="@*android:string/config_headlineFontFamilyMedium"
            android:gravity="center_vertical"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="@dimen/alert_slider_text_size"
            android:scrollHorizontally="true"
            android:ellipsize="marquee"
            android:lines="1" />
    </LinearLayout>
</LinearLayout>
