allow rild mnt_vendor_file:dir search;
allow rild oplus_reserve_file_type:dir search;
rw_dir_file(rild, oplus_reserve_radio_file_type)

allow rild vendor_proc_display:file r_file_perms;

hal_client_domain(rild, vendor_hal_oplus_commcenter)

r_dir_file(rild, vendor_proc_engineer)

get_prop(rild, boot_status_prop)
set_prop(rild, vendor_nw_exported_system_prop)
set_prop(rild, vendor_ssr_prop)

get_prop(rild, vendor_pd_locater_dbg_prop)

# Silence harmless denial: rild probes /data/ root dir for write access
# during modem init. AOSP neverallow prevents allow rule on
# system_data_root_file — rild falls back gracefully without it.
dontaudit rild system_data_root_file:dir write;

# Allow rild to resolve /cache symlink for modem cache path
allow rild cache_file:lnk_file read;
